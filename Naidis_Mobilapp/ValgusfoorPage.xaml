<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:shapes="clr-namespace:Microsoft.Maui.Controls.Shapes;assembly=Microsoft.Maui.Controls"
             x:Class="Naidis_Mobilapp.ValgusfoorPage"
             Title="Valgusfoor">

    <ScrollView>
        <VerticalStackLayout x:Name="vsl"
                             Spacing="15"
                             Padding="20"
                             BackgroundColor="#DCDCDC">

            <!-- Status label -->
            <Label x:Name="statusLabel"
                   Text="Vali valgus"
                   FontSize="24"
                   FontAttributes="Bold"
                   TextColor="White"
                   HorizontalOptions="Center"
                   Margin="0,10,0,10" />

            <!-- Traffic light box -->
            <Border x:Name="foorikast"
                    BackgroundColor="#3C3C3C"
                    Padding="30,20"
                    HorizontalOptions="Center"
                    WidthRequest="160"
                    StrokeThickness="3"
                    Stroke="DarkGray">
                <Border.StrokeShape>
                    <shapes:RoundRectangle CornerRadius="20" />
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="15">

                    <!-- Red light -->
                    <Grid HorizontalOptions="Center" VerticalOptions="Center">
                        <shapes:Ellipse x:Name="punane"
                                        WidthRequest="90" HeightRequest="90"
                                        Fill="#B4B4B4"
                                        Stroke="DarkGray"
                                        StrokeThickness="3" />
                        <Label x:Name="lblPunane"
                               Text="punane"
                               TextColor="White"
                               FontAttributes="Bold"
                               FontSize="14"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
                    </Grid>

                    <!-- Yellow light -->
                    <Grid HorizontalOptions="Center" VerticalOptions="Center">
                        <shapes:Ellipse x:Name="kollane"
                                        WidthRequest="90" HeightRequest="90"
                                        Fill="#B4B4B4"
                                        Stroke="DarkGray"
                                        StrokeThickness="3" />
                        <Label x:Name="lblKollane"
                               Text="kollane"
                               TextColor="White"
                               FontAttributes="Bold"
                               FontSize="14"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
                    </Grid>

                    <!-- Green light -->
                    <Grid HorizontalOptions="Center" VerticalOptions="Center">
                        <shapes:Ellipse x:Name="roheline"
                                        WidthRequest="90" HeightRequest="90"
                                        Fill="#B4B4B4"
                                        Stroke="DarkGray"
                                        StrokeThickness="3" />
                        <Label x:Name="lblRoheline"
                               Text="roheline"
                               TextColor="White"
                               FontAttributes="Bold"
                               FontSize="14"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
                    </Grid>

                </VerticalStackLayout>
            </Border>

            <!-- Button row 1: Sisse / Välja -->
            <HorizontalStackLayout Spacing="12" HorizontalOptions="Center">
                <Button x:Name="btnSisse"
                        Text="SISSE"
                        BackgroundColor="DarkGreen"
                        TextColor="White"
                        FontSize="15"
                        FontFamily="BobloxFont"
                        CornerRadius="10"
                        HeightRequest="44"
                        Padding="14,0"
                        Clicked="OnSisseClicked" />
                <Button x:Name="btnValja"
                        Text="VÄLJA"
                        BackgroundColor="DarkRed"
                        TextColor="White"
                        FontSize="15"
                        FontFamily="BobloxFont"
                        CornerRadius="10"
                        HeightRequest="44"
                        Padding="14,0"
                        Clicked="OnValjaClicked" />
            </HorizontalStackLayout>

            <!-- Button row 2: Auto / Öörežiim / Tagasi -->
            <HorizontalStackLayout Spacing="12" HorizontalOptions="Center">
                <Button x:Name="btnAuto"
                        Text="⏱ Automaat"
                        BackgroundColor="DarkOrange"
                        TextColor="White"
                        FontSize="15"
                        FontFamily="BobloxFont"
                        CornerRadius="10"
                        HeightRequest="44"
                        Padding="14,0"
                        Clicked="OnAutoClicked" />
                <Button x:Name="btnOo"
                        Text="🌙 Öörežiim"
                        BackgroundColor="DarkSlateBlue"
                        TextColor="White"
                        FontSize="15"
                        FontFamily="BobloxFont"
                        CornerRadius="10"
                        HeightRequest="44"
                        Padding="14,0"
                        Clicked="OnOoClicked" />
                <Button Text="← Tagasi"
                        BackgroundColor="Gray"
                        TextColor="White"
                        FontSize="15"
                        FontFamily="BobloxFont"
                        CornerRadius="10"
                        HeightRequest="44"
                        Padding="14,0"
                        Clicked="OnTagasiClicked" />
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
