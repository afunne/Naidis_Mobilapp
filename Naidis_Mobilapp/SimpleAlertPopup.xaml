<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:toolkit="clr-namespace:CommunityToolkit.Maui.Views;assembly=CommunityToolkit.Maui"
               x:Class="Naidis_Mobilapp.SimpleAlertPopup">
    <VerticalStackLayout Padding="20" Spacing="15" BackgroundColor="White" WidthRequest="300">
        <Label x:Name="TitleLabel" FontSize="24" FontAttributes="Bold" TextColor="Black" />
        <Label x:Name="MessageLabel" FontSize="18" TextColor="Black" />
        <Button Text="OK" Clicked="OnOkClicked" HorizontalOptions="Center" />
    </VerticalStackLayout>
</toolkit:Popup>
